{
    "name": "campus/portal",
    "description": "Unified Campus Operations & Logistics Management Portal",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "topthink/framework": "^6.1",
        "topthink/think-orm": "^2.0",
        "topthink/think-migration": "^3.0",
        "firebase/php-jwt": "^6.10",
        "mpdf/mpdf": "^8.2",
        "phpoffice/phpspreadsheet": "^2.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "guzzlehttp/guzzle": "^7.8"
    },
    "autoload": {
        "psr-4": {
            "app\\": "app/",
            "think\\": "vendor/topthink/framework/src/think/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "tests\\": "tests/"
        }
    },
    "config": {
        "vendor-dir": "vendor"
    },
    "scripts": {
        "post-autoload-dump": [
            "think\\composer\\ComposerScripts::postAutoloadDump"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
